  m_GameObject: {fileID: 1919227230}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6e7f35d7b7f1d7d45a466215958cc501, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MiraBasementInteract
  dialogueTypewriter: {fileID: 602701412}
  miraLines:
  - speakerName: Kael
    dialogueText: Mira, wake up...
    portrait: {fileID: 4237676072881026496, guid: 454d1fec3dbc81d4d844ac949f7fb6b6, type: 3}
  - speakerName: Mira
    dialogueText: ugh
    portrait: {fileID: 228634936585421020, guid: 6bfd52b4d3277b4478a97338eea14399, type: 3}
  - speakerName: Mira
    dialogueText: Kael... everything hurts and I can't move.
    portrait: {fileID: 228634936585421020, guid: 6bfd52b4d3277b4478a97338eea14399, type: 3}
  - speakerName: Mira
    dialogueText: 'Please help me by getting me a [Heath Potion]'
    portrait: {fileID: 228634936585421020, guid: 6bfd52b4d3277b4478a97338eea14399, type: 3}
  - speakerName: Kael
    dialogueText: Ok, I'll be back
    portrait: {fileID: 2034640904416277011, guid: ecd0716ae287d5b439e7acbfa289bda9, type: 3}
  - speakerName: Kael
    dialogueText: (I have to go upstairs...)
    portrait: {fileID: 2034640904416277011, guid: ecd0716ae287d5b439e7acbfa289bda9, type: 3}
