--- !u!114 &1919227233
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1919227230}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6e7f35d7b7f1d7d45a466215958cc501, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MiraBasementInteract
  dialogueTypewriter: {fileID: 602701412}
  miraLines:
  - speakerName: Kael
    dialogueText: Mira, wake up...
    portrait: {fileID: 4237676072881026496, guid: 454d1fec3dbc81d4d844ac949f7fb6b6, type: 3}
  - speakerName: Mira
    dialogueText: ugh
    portrait: {fileID: 228634936585421020, guid: 6bfd52b4d3277b4478a97338eea14399, type: 3}
  - speakerName: Mira
    dialogueText: Kael... everything hurts and I can't move.
    portrait: {fileID: 228634936585421020, guid: 6bfd52b4d3277b4478a97338eea14399, type: 3}
  - speakerName: Mira
    dialogueText: 'Please help me by getting me a [Heath Potion]'
    portrait: {fileID: 228634936585421020, guid: 6bfd52b4d3277b4478a97338eea14399, type: 3}
  - speakerName: Kael
    dialogueText: Ok, I'll be back
    portrait: {fileID: 2034640904416277011, guid: ecd0716ae287d5b439e7acbfa289bda9, type: 3}
  - speakerName: Kael
    dialogueText: (I have to go upstairs...)
    portrait: {fileID: 2034640904416277011, guid: ecd0716ae287d5b439e7acbfa289bda9, type: 3}
--- !u!114 &1919227234
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1919227230}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4fa8cf7c61181d441ad7e6fac9db6ac8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MiraHealthPotionInteraction
  requiredPotionName: '[Health Potion]'
  dialogueTypewriter: {fileID: 602701412}
  noPotionDialogue: []
  hasPotionDialogue:
  - speakerName: Mira
    dialogueText: Whew... Thank you.
    portrait: {fileID: -5930123909296542379, guid: e5f803cd17759d34197088275e047d86, type: 3}
  - speakerName: Mira
    dialogueText: I'm feeling a lot better!
    portrait: {fileID: -5930123909296542379, guid: e5f803cd17759d34197088275e047d86, type: 3}
  - speakerName: Mira
    dialogueText: Woah wait, what is the holy Paladin from the city doing with you?
    portrait: {fileID: -2702553545466948747, guid: d856ee498bcf75445ae98eecb26cdfc0, type: 3}
  - speakerName: Paladin
    dialogueText: So... this is the person you wanted to save with that potion.
    portrait: {fileID: -6226177044132118711, guid: c2f8b7f7382e1d14882a29e8ab0e366d, type: 3}
  - speakerName: Paladin
    dialogueText: 'I can feel a large amount of mana within her. '
    portrait: {fileID: 4907242074090915066, guid: 0fc49aca0aa58be459d3df532d47cdfa, type: 3}
  - speakerName: Kael
    dialogueText: Mira... follow us, we'll explain on the way
    portrait: {fileID: 2034640904416277011, guid: ecd0716ae287d5b439e7acbfa289bda9, type: 3}
  alreadyJoinedDialogue: []
  partyJoinAnnouncement: {fileID: 474615226}
  joinMessage: Mira has joined your party.
  injuredMiraVisual: {fileID: 713222461}
  recoveredMiraVisual: {fileID: 0}
  interactionTrigger: {fileID: 1919227232}
  disableAfterRecruitment: 1
  miraFollowerPrefab: {fileID: 8162663909719026417, guid: 2fb86771f198df04d81a087b15f41582, type: 3}
  miraSpawnDistance: 1.6
