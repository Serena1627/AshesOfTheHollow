--- !u!114 &1724305601
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1724305600}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5431ca0cb46267d40890c631287d2cdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BasementDialogueSequence
  dialogueTypewriter: {fileID: 602701412}
  openingDialogue:
  - speakerName: Kael
    dialogueText: (What happened... we're in the basement)
    portrait: {fileID: 4237676072881026496, guid: 454d1fec3dbc81d4d844ac949f7fb6b6, type: 3}
  - speakerName: Kael
    dialogueText: I need to check on Mira, but first, let me check out what's in
      that chest.
    portrait: {fileID: 2034640904416277011, guid: ecd0716ae287d5b439e7acbfa289bda9, type: 3}
  - speakerName: Kael
    dialogueText: My father used to never let us touch it, but something is shining
      inside.
    portrait: {fileID: 2034640904416277011, guid: ecd0716ae287d5b439e7acbfa289bda9, type: 3}
  openingDialogueDelay: 0.75
  afterChestDialogue:
  - speakerName: Kael
    dialogueText: What's this!?
    portrait: {fileID: 8859943044834607501, guid: 5740df5ceb0432741999c0000f641d68, type: 3}
  - speakerName: Kael
    dialogueText: I got a sword and some armor even though I didn't even put anything
      on. This isn't a normal sword.
    portrait: {fileID: 2034640904416277011, guid: ecd0716ae287d5b439e7acbfa289bda9, type: 3}
  afterChestDialogueDelay: 0.35
