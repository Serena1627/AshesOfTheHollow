--- !u!114 &1846216746
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1846216744}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e995e582dea20c94dbc6f6750cff1e81, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LioraMonkeyVictoryRecruitment
  monkeyEncounterId: LioraScene_Monkey_01
  dialogueTypewriter: {fileID: 2014584255}
  postBattleDialogue:
  - speakerName: Liora
    dialogueText: Thank you for helping me.
    portrait: {fileID: -4815526334075301163, guid: 816ce70ca7dffcd46b8300b1b65860c6, type: 3}
  - speakerName: Kael
    dialogueText: Phew... no problem
    portrait: {fileID: 916980491678386829, guid: 93d113911d16f1141b97500ebc7b7f9b, type: 3}
  - speakerName: Paladin
    dialogueText: 'The Hollow Choir has angered many creatures with their sorcery.
      That monkey was no exception. '
    portrait: {fileID: 4907242074090915066, guid: 0fc49aca0aa58be459d3df532d47cdfa, type: 3}
  - speakerName: Liora
    dialogueText: That cult again... they destroyed my village.
    portrait: {fileID: 8706523877615525295, guid: 5187f6fd809c4714480ab1d5aa09aff2, type: 3}
  - speakerName: Mira
    dialogueText: They destroyed our village too and this Paladin is from the holy
      city here to hunt down the cult.
    portrait: {fileID: -3849295907798211252, guid: d3a95522b75e4044ab08aef4c5443c73, type: 3}
  - speakerName: Mira
