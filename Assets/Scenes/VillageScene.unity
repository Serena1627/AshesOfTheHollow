  dialogueTypewriter: {fileID: 863154642}
  miraFirstVillageDialogue:
  - speakerName: Mira
    dialogueText: ...
    portrait: {fileID: 1846242280849721910, guid: d6313f8db48e88247b8d9ecde22bf3ac, type: 3}
  - speakerName: Mira
    dialogueText: So that's what happened...
    portrait: {fileID: 1846242280849721910, guid: d6313f8db48e88247b8d9ecde22bf3ac, type: 3}
  - speakerName: Paladin
    dialogueText: It is likely that your parents have similar quality souls to yours,
      so there's a chance they are still alive
    portrait: {fileID: 4907242074090915066, guid: 0fc49aca0aa58be459d3df532d47cdfa, type: 3}
  - speakerName: Paladin
    dialogueText: But we must make haste...
    portrait: {fileID: 4907242074090915066, guid: 0fc49aca0aa58be459d3df532d47cdfa, type: 3}
  dialogueDelay: 0.2
  disablePlayerMovementDuringDialogue: 0
