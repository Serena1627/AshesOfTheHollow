--- !u!114 &667416792
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 667416789}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 31ac0d6a1f719ac419ffd043ac9749a7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::PaladinRecruitInteraction
  dialogueTypewriter: {fileID: 863154642}
  recruitmentDialogue:
  - speakerName: Paladin
    dialogueText: Oh, there's a survivor still here.
    portrait: {fileID: 4907242074090915066, guid: 0fc49aca0aa58be459d3df532d47cdfa, type: 3}
  - speakerName: Paladin
    dialogueText: Wait... that sword... that armor...
    portrait: {fileID: -6226177044132118711, guid: c2f8b7f7382e1d14882a29e8ab0e366d, type: 3}
  - speakerName: Paladin
    dialogueText: Are you the son of Erynd?
    portrait: {fileID: 4907242074090915066, guid: 0fc49aca0aa58be459d3df532d47cdfa, type: 3}
  - speakerName: Kael
    dialogueText: You know who my father is?
    portrait: {fileID: 8859943044834607501, guid: 5740df5ceb0432741999c0000f641d68, type: 3}
  - speakerName: Paladin
    dialogueText: On another note, there are still cultists close by, we need to
      get to them and defeat them.
    portrait: {fileID: 4907242074090915066, guid: 0fc49aca0aa58be459d3df532d47cdfa, type: 3}
  - speakerName: Kael
    dialogueText: 'Cultists? What''s going on? '
    portrait: {fileID: 4237676072881026496, guid: 454d1fec3dbc81d4d844ac949f7fb6b6, type: 3}
  - speakerName: Paladin
    dialogueText: I'll explain later but we don't have much time.
    portrait: {fileID: 4907242074090915066, guid: 0fc49aca0aa58be459d3df532d47cdfa, type: 3}
  - speakerName: Paladin
    dialogueText: Quick, head upwards. I'll come with you.
    portrait: {fileID: 4907242074090915066, guid: 0fc49aca0aa58be459d3df532d47cdfa, type: 3}
  partyJoinAnnouncement: {fileID: 113144027}
  joinMessage: Paladin has joined your party.
  interactionTrigger: {fileID: 667416791}
  paladinNpcVisual: {fileID: 237661098}
  paladinFollowerPrefab: {fileID: 8162663909719026417, guid: 5c91643223aee234384968e5b30cb0cf, type: 3}
  followerSpawnDistance: 1.1
  spawnFollowerAfterRecruitment: 1
